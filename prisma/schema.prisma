generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  TREKKER
  LEADER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  profileImage  String?
  bio           String?   
  country       String?
  password      String?
  role          UserRole  @default(TREKKER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  medicalProfile MedicalProfile?
  bookings       Booking[]
  treks          Trek[]          @relation("GuideTreks")
  reviews        Review[]
  posts          ExpeditionPost[]
  comments       PostComment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum MedicalStatus {
  NONE
  AWAITING_CLEARANCE
  IN_REVIEW
  CLEARED
}

model MedicalProfile {
  id        String        @id @unique @default(cuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id])
  vitals    Json?
  history   Json?
  fitness   Json?
  status    MedicalStatus @default(NONE)
  medicalNotes String?    
  updatedAt DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ExpeditionStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Expedition {
  id        String           @id @default(cuid())
  trekId    String
  trek      Trek             @relation(fields: [trekId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    ExpeditionStatus @default(UPCOMING)

  currentLocationName String?
  currentAltitude     Int?
  currentLat          Float?
  currentLong         Float?
  progressPercent     Int     @default(0)

  bookings Booking[]
  posts    ExpeditionPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PostType {
  MESSAGE
  UPDATE
  MILESTONE
  IMAGE
  ALERT
}

model ExpeditionPost {
  id           String     @id @default(cuid())
  expeditionId String
  expedition   Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  content      String     
  type         PostType   @default(MESSAGE)
  mediaUrl     String?
  
  comments     PostComment[]
  reactions    Json?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([expeditionId])
  @@index([userId])
}

model PostComment {
  id      String         @id @default(cuid())
  postId  String
  post    ExpeditionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId  String
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content String         
  
  createdAt DateTime     @default(now())

  @@index([postId])
}

model Booking {
  id String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trekId String
  trek   Trek   @relation(fields: [trekId], references: [id], onDelete: Restrict)
  expeditionId String?
  expedition   Expedition? @relation(fields: [expeditionId], references: [id])
  participants Int           @default(1)
  totalPrice   Float         @default(0)
  status       BookingStatus @default(PENDING)
  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([trekId])
}

model Trek {
  id           String   @id @default(cuid())
  title        String
  description  String   
  location     String
  durationDays Int
  difficulty   String
  price        Float
  maxAltitude  Int?
  bestSeason   String?
  highlights   String[]
  coverImage   String?
  availableSpots Int @default(15)
  maxCapacity    Int @default(20)
  embedding      Float[]
  guideId  String?
  guide    User?     @relation("GuideTreks", fields: [guideId], references: [id])
  reviews  Review[]
  bookings Booking[]
  expeditions Expedition[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ip        String
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trekId    String
  trek      Trek     @relation(fields: [trekId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}