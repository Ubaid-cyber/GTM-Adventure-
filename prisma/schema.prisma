generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  phone          String?          @unique
  emailVerified  DateTime?
  profileImage   String?
  password       String?
  role           UserRole         @default(TREKKER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  bio            String?
  country        String?
  accounts       Account[]
  bookings       Booking[]
  posts          ExpeditionPost[]
  medicalProfile MedicalProfile?
  comments       PostComment[]
  reviews        Review[]
  sessions       Session[]
  treks          Trek[]           @relation("GuideTreks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MedicalProfile {
  id           String        @id @unique @default(cuid())
  userId       String        @unique
  vitals       Json?
  history      Json?
  fitness      Json?
  updatedAt    DateTime      @updatedAt
  medicalNotes String?
  status       MedicalStatus @default(NONE)
  user         User          @relation(fields: [userId], references: [id])
}

model Expedition {
  id                  String           @id @default(cuid())
  trekId              String
  startDate           DateTime
  endDate             DateTime
  status              ExpeditionStatus @default(UPCOMING)
  currentLocationName String?
  currentAltitude     Int?
  currentLat          Float?
  currentLong         Float?
  progressPercent     Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  bookings            Booking[]
  trek                Trek             @relation(fields: [trekId], references: [id])
  posts               ExpeditionPost[]
}

model ExpeditionPost {
  id           String        @id @default(cuid())
  expeditionId String
  userId       String
  content      String
  type         PostType      @default(MESSAGE)
  mediaUrl     String?
  reactions    Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expedition   Expedition    @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments     PostComment[]

  @@index([expeditionId])
  @@index([userId])
}

model PostComment {
  id        String         @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime       @default(now())
  post      ExpeditionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Booking {
  id                String        @id @default(cuid())
  userId            String
  trekId            String
  expeditionId      String?
  participants      Int           @default(1)
  totalPrice        Float         @default(0)
  status            BookingStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  basePrice         Float?        @default(0)
  gstAmount         Float?        @default(0)
  refundAmount      Float?        @default(0)
  refundId          String?       @unique
  expedition        Expedition?   @relation(fields: [expeditionId], references: [id])
  trek              Trek          @relation(fields: [trekId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trekId])
}

model Trek {
  id               String       @id @default(cuid())
  title            String
  description      String
  location         String
  durationDays     Int
  difficulty       String
  price            Float
  maxAltitude      Int?
  bestSeason       String?
  highlights       String[]
  itinerary        Json?
  inclusions       String[]     @default([])
  exclusions       String[]     @default([])
  gearRequirements String[]     @default([])
  coverImage       String?
  availableSpots   Int          @default(15)
  maxCapacity      Int          @default(20)
  embedding        Float[]
  guideId          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  bookings         Booking[]
  expeditions      Expedition[]
  reviews          Review[]
  guide            User?        @relation("GuideTreks", fields: [guideId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ip        String
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  trekId    String
  createdAt DateTime @default(now())
  trek      Trek     @relation(fields: [trekId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTP {
  id        String   @id
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

enum UserRole {
  TREKKER
  LEADER
  ADMIN
}

enum MedicalStatus {
  NONE
  AWAITING_CLEARANCE
  IN_REVIEW
  CLEARED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ExpeditionStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum PostType {
  MESSAGE
  UPDATE
  MILESTONE
  IMAGE
  ALERT
}
