{
  "name": "gtm-adventure",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "seed": "npx tsx scripts/seed-treks.ts",
    "seed:admin": "npx tsx scripts/seed-admin.ts",
    "db:generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^5.21.1",
    "@prisma/engines": "5.21.1",
    "concurrently": "^9.1.2",
    "prisma": "^5.21.1",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@prisma/adapter-pg": "5.21.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "otplib": "^13.4.0",
    "pg": "^8.20.0"
  }
}
